# Weekly Yield Report Email Configuration

# SMTP Configuration
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yieldaggregator.com
SMTP_REPLY_TO=support@yieldaggregator.com

# Dashboard URL (used in email links)
DASHBOARD_URL=https://app.yieldaggregator.com

# Weekly Report Job Configuration
# Cron expression: "0 9 * * 1" = Every Monday at 9 AM
WEEKLY_REPORT_SCHEDULE=0 9 * * 1

# Enable/disable email sending
WEEKLY_REPORT_SEND_EMAILS=true

# Filter reports to only include those with yield activity
WEEKLY_REPORT_FILTER_BY_ACTIVITY=true

# Enable detailed logging
WEEKLY_REPORT_LOG_RESULTS=true

# Optional: Webhook for job completion notifications
# WEEKLY_REPORT_WEBHOOK_URL=https://your-webhook.com/reports

# Optional: Slack webhook for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Email list for job failure notifications
# ADMIN_EMAIL=admin@example.com

# Optional: Maximum number of emails to send per batch
# BATCH_EMAIL_SIZE=100

# Optional: Delay between batch emails (milliseconds)
# BATCH_EMAIL_DELAY=1000

# Optional: Enable email preview mode (don't actually send)
# EMAIL_PREVIEW_MODE=false

# Optional: Test email recipient (for testing)
# TEST_EMAIL_RECIPIENT=test@example.com
