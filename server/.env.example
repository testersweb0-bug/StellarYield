# Server configuration. Copy to server/.env for local development.
# Never commit real secrets, private keys, database credentials, or webhook URLs.

# Local server
NODE_ENV=development
PORT=3001
DASHBOARD_URL=http://localhost:5173

# Database. Optional for basic local API usage, required for production jobs/routes.
MONGODB_URI=
MONGODB_DB_NAME=stellar_yield
DATABASE_URL=

# Stellar / Soroban network
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Relayer. Required before using /api/relayer/fee-bump.
RELAYER_SECRET_KEY=

# Metrics. Required in production to protect /api/metrics.
METRICS_TOKEN=

# Zap quotes and supported assets
DEX_ROUTER_CONTRACT_ID=
ZAP_QUOTE_SIM_SOURCE_ACCOUNT=
ZAP_FALLBACK_NUMERATOR=1
ZAP_FALLBACK_DENOMINATOR=1
ZAP_ASSETS_JSON=
XLM_SAC_CONTRACT_ID=
USDC_SAC_CONTRACT_ID=
AQUA_SAC_CONTRACT_ID=
VAULT_TOKEN_CONTRACT_ID=
VAULT_TOKEN_DECIMALS=7
VAULT_TOKEN_SYMBOL=USDC
VAULT_CONTRACT_ID=

# Fee oracle
FEE_ORACLE_LEDGER_SAMPLE_SIZE=20
FEE_ORACLE_MIN_BASE_FEE=100
FEE_ORACLE_CACHE_TTL_MS=30000

# AI risk agent. Optional unless AI analysis is enabled.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email and reports. Optional for local development.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yieldaggregator.com
SMTP_REPLY_TO=

# Webhooks and storage. Optional unless the related monitor/IPFS feature is enabled.
DISCORD_WEBHOOK_URL=
PINATA_JWT=
AUDIT_LOG_DIR=./audit-logs
AUDIT_SIGNING_KEY=
