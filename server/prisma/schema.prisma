generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(uuid())
  ledger          Int
  txHash          String
  contractId      String
  topic           String
  data            String   // XDR encoded or parsed JSON
  createdAt       DateTime @default(now())

  @@unique([txHash, topic, data]) // Idempotency
}

model IndexerState {
  id              String   @id @default("singleton")
  lastLedger      Int
}

model VaultBalance {
  id              String   @id @default(uuid())
  walletAddress   String   @unique
  tvl             Float    @default(0)
  totalYield      Float    @default(0)
  updatedAt       DateTime @updatedAt
}

model Notification {
  id              String   @id @default(uuid())
  walletAddress   String
  type            String   // DEPOSIT, WITHDRAWAL, ANNOUNCEMENT, HARVEST
  title           String
  message         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model OnRampTransaction {
  id              String   @id @default(uuid())
  walletAddress   String
  provider        String   // STRIPE, MOONPAY
  status          String   // PENDING, COMPLETED, FAILED
  amountFiat      Float
  currency        String
  amountUsdc      Float    @default(0)
  providerTxId    String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── PnL Engine Models (Issue #107) ──────────────────────────────────────

model SharePriceSnapshot {
  id              String   @id @default(uuid())
  vaultId         String
  sharePrice      Float    // price per share in USDC (or base asset)
  totalShares     Float
  totalAssets     Float
  snapshotAt      DateTime @default(now())

  @@index([vaultId, snapshotAt])
}

model UserTransaction {
  id              String   @id @default(uuid())
  walletAddress   String
  vaultId         String
  action          String   // DEPOSIT, WITHDRAW, HARVEST
  amount          Float    // amount in base asset (USDC)
  shares          Float    // shares minted or burned
  sharePriceAtTx  Float    // share price at time of transaction
  txHash          String   @unique
  timestamp       DateTime
  createdAt       DateTime @default(now())

  @@index([walletAddress, vaultId])
  @@index([walletAddress, timestamp])
}

// ── CSV Export Models (Issue #113) ──────────────────────────────────────

model ExportJob {
  id              String   @id @default(uuid())
  walletAddress   String
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileUrl         String?
  error           String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([walletAddress, createdAt])
}

// ── Referral System Models (Issue #115) ─────────────────────────────────

model Referral {
  id              String   @id @default(uuid())
  referrerAddress String
  refereeAddress  String   @unique
  referredTvl     Float    @default(0)
  totalRewards    Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([referrerAddress])
}

// ── APY Alert Models ─────────────────────────────────────────────────────────

model UserAlert {
  id              String   @id @default(uuid())
  walletAddress   String
  vaultId         String   // protocol name / vault identifier
  condition       String   // "above" | "below"
  thresholdValue  Float    // APY percentage threshold (e.g. 10.0 for 10%)
  email           String   // destination email for notifications
  status          String   @default("active") // "active" | "triggered" | "deleted"
  triggeredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([walletAddress])
  @@index([status, vaultId])
}

// ── Encrypted Address Book Models (Issue #140) ───────────────────────────────

model Contact {
  id                String   @id @default(uuid())
  walletAddress     String   // Owner's wallet address
  encryptedName     String   // Base64 encrypted contact name
  encryptedAddress  String   // Base64 encrypted contact address
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([walletAddress, createdAt])
  @@unique([walletAddress, encryptedAddress]) // Prevent duplicates per user
}

// ── Risk Incident Models (#286) ───────────────────────────────────────────

model Incident {
  id              String   @id @default(uuid())
  protocol        String   // protocol name (Blend, Soroswap, etc.)
  severity        String   // LOW, MEDIUM, HIGH, CRITICAL
  type            String   // PAUSE, ANOMALY, DEPEG, EXPLOIT, INTERVENTION
  title           String
  description     String
  affectedVaults  String[] // Array of vault IDs/names
  resolved        Boolean  @default(false)
  startedAt       DateTime
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([protocol, severity])
  @@index([startedAt])
}
