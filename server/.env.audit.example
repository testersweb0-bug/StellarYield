# Audit Trail Configuration

# Directory where audit logs will be stored
# Default: ./audit-logs
AUDIT_LOG_DIR=./audit-logs

# Signing key for HMAC-SHA256 signatures
# Should be a strong, random string
# In production, use a secure key management system
AUDIT_SIGNING_KEY=your-secure-signing-key-change-this-in-production

# Optional: Enable audit logging for specific endpoints only
# AUDIT_ENABLED_ENDPOINTS=/api/admin/*,/api/vaults/*

# Optional: Exclude certain endpoints from audit logging
# AUDIT_EXCLUDED_ENDPOINTS=/api/health,/api/metrics

# Optional: Maximum number of audit entries to keep in memory
# Default: 10000
# AUDIT_MEMORY_LIMIT=10000

# Optional: Enable audit log rotation (requires database)
# AUDIT_LOG_ROTATION_ENABLED=false
# AUDIT_LOG_ROTATION_DAYS=30

# Optional: Enable encryption for audit logs at rest
# AUDIT_ENCRYPTION_ENABLED=false
# AUDIT_ENCRYPTION_KEY=your-encryption-key

# Optional: Enable audit log replication
# AUDIT_REPLICATION_ENABLED=false
# AUDIT_REPLICATION_TARGETS=https://backup-server.com/audit

# Optional: Audit log retention policy
# AUDIT_RETENTION_DAYS=365

# Optional: Enable real-time audit alerts
# AUDIT_ALERTS_ENABLED=true
# AUDIT_ALERTS_WEBHOOK=https://your-webhook.com/alerts

# Optional: Audit log compression
# AUDIT_COMPRESSION_ENABLED=false
# AUDIT_COMPRESSION_ALGORITHM=gzip
